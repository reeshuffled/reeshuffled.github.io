# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# Last.fm (incremental scrobble fetcher)
# Used by: pipenv run prepare lastfm_api lastfm_insights_api
LASTFM_API_KEY=
LASTFM_USER=
# Comma-separated artist names to exclude from lastfm output
LASTFM_ARTIST_BLOCKLIST=

# Trakt (incremental TV watch history via API)
# One-time setup: pipenv run trakt-auth --client-id <id> --client-secret <secret>
# Create an app at https://trakt.tv/oauth/applications/new first.
# Used by: pipenv run prepare trakt trakt_api
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=
TRAKT_ACCESS_TOKEN=
TRAKT_REFRESH_TOKEN=
# Comma-separated show titles to exclude from tv.json output
TRAKT_SHOW_BLOCKLIST=

# MAL filter list — comma-separated Japanese titles to exclude from anime.json
# Used by: pipenv run prepare mal
MAL_FILTER_LIST=

# Letterboxd (RSS diary top-up)
# Your Letterboxd username (as in letterboxd.com/<user>/rss/)
# Backfill first: from lib.etl import sources; sources.seed_letterboxd_cache_from_csv()
# Used by: pipenv run prepare movies_api
LETTERBOXD_USER=

# TMDB (movie enrichment for Letterboxd data — genres, runtime, overview, poster)
# Free key — https://www.themoviedb.org/settings/api
# Used by: pipenv run prepare movies_api (optional; skipped if unset)
TMDB_API_KEY=

# Goodreads (paginated shelf RSS — no API key required for public profiles)
# Your numeric Goodreads user ID (from the URL on your profile page)
# Used by: pipenv run prepare books_api
GOODREADS_USER_ID=

# MyAnimeList (per-anime API enrichment)
# Used by: pipenv run prepare mal
MAL_CLIENT_ID=

# Google service account (Sheets API + Calendar API, read-only)
# 1. Create a service account in Google Cloud Console and enable Sheets API + Calendar API.
# 2. Download the JSON key and save it under input/ (gitignored).
# 3. Share each Sheet and the Calendar with the service account's client_email (read-only).
# Used by: pipenv run prepare dvd_api games_api records_api fragrance_api lifting_api
GOOGLE_SERVICE_ACCOUNT_FILE=input/google-service-account.json
GAMES_SHEET_ID=
RECORDS_SHEET_ID=
FRAGRANCE_SHEET_ID=
# Calendar ID for lifting events (usually your Gmail address, or a specific calendar's ID)
LIFTING_CALENDAR_ID=
