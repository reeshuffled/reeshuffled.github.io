# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# Last.fm (incremental scrobble fetcher)
# Used by: pipenv run prepare lastfm_api lastfm_insights_api
LASTFM_API_KEY=
LASTFM_USER=

# Trakt (incremental TV watch history via API)
# One-time setup: pipenv run trakt-auth --client-id <id> --client-secret <secret>
# Create an app at https://trakt.tv/oauth/applications/new first.
# Used by: pipenv run prepare trakt_api
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=
TRAKT_ACCESS_TOKEN=
TRAKT_REFRESH_TOKEN=

# Letterboxd (RSS diary top-up)
# Your Letterboxd username (as in letterboxd.com/<user>/rss/)
# Backfill first: from lib.etl import sources; sources.seed_letterboxd_cache_from_csv()
# Used by: pipenv run prepare movies_api
LETTERBOXD_USER=

# Goodreads (paginated shelf RSS — no API key required for public profiles)
# Your numeric Goodreads user ID (from the URL on your profile page)
# Used by: pipenv run prepare books_api
GOODREADS_USER_ID=

# MyAnimeList (per-anime API enrichment)
# Used by: pipenv run prepare mal
MAL_CLIENT_ID=
