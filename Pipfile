[[source]]
url = "https://pypi.org/simple"
verify_ssl = true
name = "pypi"

[packages]
beautifulsoup4 = "*"
oyaml = "*"
numpy = "*"
pydriller = "*"
python-frontmatter = "*"
requests = "*"
sentence-transformers = "*"
tabulate = "*"
umap-learn = "*"
xmltodict = "*"
python-dotenv = "*"
ics = "*"
icalendar = "*"
lxml = "*"
openpyxl = "*"
matplotlib = "*"

[requires]
python_version = "3.13"

[scripts]
fmt = "ruff format ."
lint = "ruff check . --fix"
clog = "python lib/cli.py changelog"
enrich = "python lib/cli.py enrich"
new = "python lib/cli.py draft"
promote = "python lib/cli.py promote"
recs = "python lib/embed.py"
start = "bundle exec jekyll serve --livereload --drafts"
stats = "python lib/cli.py stats"
prepare = "python lib/cli.py prepare"

[dev-packages]
ruff = "*"
pytest = "*"
pytest-cov = "*"
