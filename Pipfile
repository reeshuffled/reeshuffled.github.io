[[source]]
url = "https://pypi.org/simple"
verify_ssl = true
name = "pypi"

[packages]
beautifulsoup4 = "*"
oyaml = "*"
numpy = "*"
pydriller = "*"
python-frontmatter = "*"
requests = "*"
sentence-transformers = "*"
tabulate = "*"
umap-learn = "*"
xmltodict = "*"
python-dotenv = "*"
ics = "*"
icalendar = "*"
lxml = "*"
openpyxl = "*"
matplotlib = "*"
gspread = "*"
google-api-python-client = "*"
google-auth = "*"
alt-profanity-check = "*"

[requires]
python_version = "3.13"

[scripts]
fmt = "ruff format ."
lint = "ruff check . --fix"
clog = "env PYTHONPATH=. python lib/cli.py changelog"
enrich = "env PYTHONPATH=. python lib/cli.py enrich"
new = "env PYTHONPATH=. python lib/cli.py draft"
promote = "env PYTHONPATH=. python lib/cli.py promote"
recs = "python lib/embed.py"
start = "bundle exec jekyll serve --livereload --drafts"
stats = "env PYTHONPATH=. python lib/cli.py stats"
prepare = "env PYTHONPATH=. python lib/cli.py prepare"
trakt-auth = "env PYTHONPATH=. python lib/cli.py trakt-auth"

[dev-packages]
ruff = "*"
pytest = "*"
pytest-cov = "*"
